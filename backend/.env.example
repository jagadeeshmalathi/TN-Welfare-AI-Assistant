# Backend configuration — copy to .env and adjust as needed.

# --- LLM provider --------------------------------------------------------- #
# Leave blank to auto-select: OpenAI if OPENAI_API_KEY is set, else Ollama.
# Force a provider with: ollama | openai
LLM_PROVIDER=

# Ollama (default, free, offline). Run `ollama pull llama3` first.
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (optional). If a key is provided, OpenAI is used automatically.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Sentence-transformer model used to embed schemes for FAISS.
EMBED_MODEL=all-MiniLM-L6-v2
# Number of schemes to retrieve per question.
RAG_TOP_K=4

# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Port the API listens on.
PORT=8000
